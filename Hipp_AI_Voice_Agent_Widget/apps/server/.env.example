# ── Vapi ─────────────────────────────────────────────────────────────────────
# Private API key: used for server-side REST calls (create/update assistants, list calls)
# Find in Vapi dashboard → Account → API Keys → "Private Key" or "Secret Key"
VAPI_PRIVATE_API_KEY=

# Webhook secret: used to validate HMAC-SHA256 signatures on incoming Vapi webhook POSTs
# Set this in Vapi dashboard → Assistant → Server URL when configuring your webhook
VAPI_WEBHOOK_SECRET=

# For reference only — NOT used by the server. Goes in the website's .env.local instead.
# VAPI_PUBLIC_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find both in Supabase dashboard → Project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # Service role key (bypasses RLS) — server-side only

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for knowledge base embeddings (text-embedding-3-small) only
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used by buildPlanService to generate post-call Demo Build Plans from transcripts
# (model: claude-sonnet-4-6). Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# ── LinkedIn Growth Engine Sheet ──────────────────────────────────────────────
# The multi-tab "LinkedIn Growth Engine — Hipp AI" sheet (Connection Queue +
# Demo Call Transcripts tabs). The demo intake service reads/writes here.
LINKEDIN_GROWTH_ENGINE_SHEET_ID=1p_WwSv2r01JsTZmp6nn9safFJ8TPoTmwVPNHNz0ZF2E

# ── Server public URL ─────────────────────────────────────────────────────────
# Used by buildPlanService to construct shareable links to /api/demo-intakes/:id/plan.
# Set to the Railway production URL.
SERVER_PUBLIC_URL=https://hipp-ai-voice-server-production.up.railway.app

# ── Calendly ─────────────────────────────────────────────────────────────────
# Personal Access Token from Calendly → Integrations → API & Webhooks → Personal Access Tokens
CALENDLY_PAT=

# Get these by calling GET https://api.calendly.com/users/me with your PAT:
# current_organization → CALENDLY_ORG_URI
# Then call GET https://api.calendly.com/event_types?organization=YOUR_ORG_URI to get event types
CALENDLY_ORG_URI=
CALENDLY_EVENT_TYPE_URI=     # URI for the default discovery/strategy call event type

# ── Google Calendar ────────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials in Google Cloud Console:
# APIs & Services → Credentials → Create Credentials → OAuth client ID → Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth/callback

# Obtained ONCE via the OAuth flow (visit http://localhost:3001/oauth/start when server is running)
# Store this permanently — googleapis auto-refreshes the access token from it
GOOGLE_REFRESH_TOKEN=

# Calendar to use for free/busy checks and event creation
GOOGLE_CALENDAR_ID=primary

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Used to send SMS booking links to phone callers
# Sign up at twilio.com → get a toll-free number → submit toll-free verification
# Find SID and Auth Token in Twilio Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=   # Your Twilio toll-free number, e.g. +18XXXXXXXXXX

# Post-call confirmation SMS to SOCIAL callers ("Dillon will get started this
# week... reply with your @"). Off by default — flip to "true" ONLY after the
# 888 number is toll-free A2P verified, or carriers will filter the texts.
# Also set the number's Messaging webhook → POST {SERVER}/twilio/sms-incoming
# so STOP opt-outs + typed @ replies are captured.
SEND_POST_CALL_SMS=false

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack Incoming Webhook URL — create at api.slack.com/apps → Incoming Webhooks
# Point it to a #voice-agent-alerts channel
NOTIFY_SLACK_WEBHOOK_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# ALLOWED_ORIGIN=https://yourdomain.com   # Restrict CORS in production

# ── Gemini Live API ────────────────────────────────────────────────────────────
# Used by the Twilio Media Streams ↔ Gemini Live WebSocket bridge for the
# voice agent. Generate at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Rotating demo line (persona routing by dialed number) ---
# The Twilio number of the demo line (E.164, e.g. +12545551234). Unset = demo personas inert.
DEMO_LINE_NUMBER=
# Which persona the demo line runs (registry key in src/config/personas.ts, e.g. "pest").
DEMO_LINE_PERSONA=
# n8n webhook the demo-line lead is POSTed to (n8n owns the CRM specifics, e.g. GorillaDesk).
DEMO_LINE_WEBHOOK_URL=
# Shared secret sent as X-Webhook-Token so the n8n webhook rejects forged posts.
DEMO_LINE_WEBHOOK_TOKEN=
# GorillaDesk (demo-line CRM target when no webhook middleware is set).
# Per-company API key from GorillaDesk's Addons page — Dillon pastes this
# into Railway himself.
GORILLADESK_API_KEY=
